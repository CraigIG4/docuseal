<% content_for :title, @company.name %>

<div class="max-w-4xl mx-auto px-4 py-8">

  <%# ── Header ─────────────────────────────────────────────────────────────── %>
  <div class="flex items-start justify-between mb-6 gap-4">
    <div>
      <div class="flex items-center gap-2 mb-1">
        <%= link_to companies_path, class: 'text-xs text-gray-400 hover:text-gray-600' do %>
          ← Counterparties
        <% end %>
      </div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @company.name %></h1>
      <% if @company.domain.present? %>
        <p class="text-sm text-gray-400 mt-0.5"><%= @company.domain %></p>
      <% end %>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <%= link_to edit_company_path(@company),
          class: 'px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-200 text-gray-600 hover:bg-gray-50' do %>
        Edit
      <% end %>
      <%= link_to new_agreement_path(company_id: @company.id),
          class: 'px-3 py-1.5 rounded-lg text-sm font-semibold text-white',
          style: 'background-color:#1a2332;' do %>
        + New Agreement
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">

    <%# Company details card %>
    <div class="md:col-span-2 rounded-xl border border-gray-200 bg-white overflow-hidden">
      <div class="px-5 py-3 border-b border-gray-100 text-xs font-semibold text-gray-500 uppercase tracking-wide"
           style="background-color:#f8fafc;">Company Details</div>
      <div class="px-5 py-4 grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
        <% if @company.registration_number.present? %>
          <div>
            <p class="text-xs text-gray-400 mb-0.5">Registration</p>
            <p class="font-medium text-gray-900"><%= @company.registration_number %></p>
          </div>
        <% end %>
        <div>
          <p class="text-xs text-gray-400 mb-0.5">Country</p>
          <p class="font-medium text-gray-900"><%= @company.country %></p>
        </div>
        <% if @company.primary_contact_name.present? || @company.primary_contact_email.present? %>
          <div class="col-span-2">
            <p class="text-xs text-gray-400 mb-0.5">Primary Contact</p>
            <p class="font-medium text-gray-900"><%= @company.primary_contact_name.presence || '—' %></p>
            <p class="text-xs text-gray-500"><%= @company.primary_contact_email.presence || '' %></p>
          </div>
        <% end %>
        <% if @company.address.present? %>
          <div class="col-span-2">
            <p class="text-xs text-gray-400 mb-0.5">Address</p>
            <p class="text-gray-700 whitespace-pre-line text-xs"><%= @company.address %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# Stats card %>
    <div class="rounded-xl border border-gray-200 bg-white overflow-hidden">
      <div class="px-5 py-3 border-b border-gray-100 text-xs font-semibold text-gray-500 uppercase tracking-wide"
           style="background-color:#f8fafc;">Activity</div>
      <div class="px-5 py-4 space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600">Agreements</span>
          <span class="text-2xl font-bold" style="color:#1a2332;"><%= @company.agreements_count %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600">Known signatories</span>
          <span class="text-2xl font-bold" style="color:#1a2332;"><%= @signatories.count %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600">Active signatories</span>
          <span class="text-lg font-semibold text-green-600"><%= @signatories.count(&:active?) %></span>
        </div>
      </div>
    </div>

  </div>

  <%# ── Signatory Memory ───────────────────────────────────────────────────── %>
  <div class="rounded-xl border border-gray-200 bg-white mb-6 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between"
         style="background-color:#f8fafc;">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
        </svg>
        <span class="text-sm font-semibold text-gray-700">Signatory Memory</span>
      </div>
      <span class="text-xs text-gray-400">Recorded automatically when counterparties sign</span>
    </div>

    <% if @signatories.any? %>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-100 bg-gray-50">
            <th class="px-5 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Name / Email</th>
            <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide hidden md:table-cell">Role</th>
            <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide hidden md:table-cell">Authority Basis</th>
            <th class="px-4 py-2.5 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">Signings</th>
            <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide hidden md:table-cell">Last Seen</th>
            <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
            <th class="px-4 py-2.5"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @signatories.each do |sig| %>
            <tr class="hover:bg-gray-50 transition-colors <%= sig.active? ? '' : 'opacity-50' %>" id="sig_<%= sig.id %>">
              <td class="px-5 py-3">
                <p class="font-medium text-gray-900"><%= sig.name %></p>
                <p class="text-xs text-gray-400"><%= sig.email %></p>
              </td>
              <td class="px-4 py-3 hidden md:table-cell">
                <%# Inline edit for role_title %>
                <%= form_with url: company_signatory_path(sig), method: :patch,
                              html: { class: 'inline', id: "rf_#{sig.id}" } do |f| %>
                  <%= f.text_field :role_title, value: sig.role_title,
                      placeholder: 'e.g. Director',
                      class: 'w-full text-xs border-0 border-b border-transparent hover:border-gray-300 focus:border-blue-400 bg-transparent py-0.5 px-0 focus:outline-none focus:ring-0',
                      onblur: "this.form.requestSubmit()" %>
                <% end %>
              </td>
              <td class="px-4 py-3 hidden md:table-cell">
                <%# Inline edit for authority_basis — shares the same form as role_title %>
                <%= form_with url: company_signatory_path(sig), method: :patch,
                              html: { class: 'inline', id: "af_#{sig.id}" } do |f| %>
                  <%= f.text_field :authority_basis, value: sig.authority_basis,
                      placeholder: 'e.g. Board resolution 15 Mar 2024',
                      class: 'w-full text-xs border-0 border-b border-transparent hover:border-gray-300 focus:border-blue-400 bg-transparent py-0.5 px-0 focus:outline-none focus:ring-0',
                      onblur: "this.form.requestSubmit()" %>
                <% end %>
              </td>
              <td class="px-4 py-3 text-center">
                <span class="inline-flex items-center justify-center w-7 h-7 rounded-full text-xs font-bold text-white"
                      style="background-color:<%= sig.times_signed > 2 ? '#1a2332' : '#6b7280' %>;">
                  <%= sig.times_signed %>
                </span>
              </td>
              <td class="px-4 py-3 hidden md:table-cell text-xs text-gray-500">
                <%= sig.last_seen_label %>
              </td>
              <td class="px-4 py-3">
                <% if sig.active? %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Active
                  </span>
                <% else %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                    <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span> Inactive
                  </span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-right">
                <%= form_with url: company_signatory_path(sig), method: :patch do |f| %>
                  <%= f.hidden_field :active, value: !sig.active? %>
                  <%= f.submit sig.active? ? 'Mark inactive' : 'Reactivate',
                      class: 'text-xs text-gray-400 hover:text-gray-700 cursor-pointer bg-none border-none underline',
                      style: 'background:none;border:none;cursor:pointer;' %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="px-5 py-10 text-center">
        <svg class="w-10 h-10 text-gray-200 mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/>
        </svg>
        <p class="text-sm text-gray-500 font-medium mb-1">No signatories recorded yet</p>
        <p class="text-xs text-gray-400">Signatories are automatically recorded the first time a counterparty signs a workflow.</p>
      </div>
    <% end %>
  </div>

  <%# ── Recent Agreements ──────────────────────────────────────────────────── %>
  <div class="rounded-xl border border-gray-200 bg-white overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100 text-sm font-semibold text-gray-700"
         style="background-color:#f8fafc;">Recent Agreements</div>
    <% if @agreements.any? %>
      <table class="w-full text-sm">
        <tbody class="divide-y divide-gray-100">
          <% @agreements.each do |ag| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-5 py-3">
                <p class="font-medium text-gray-900"><%= ag.agreement_type_label %></p>
                <p class="text-xs text-gray-400"><%= ag.created_at.strftime('%d %b %Y') %></p>
              </td>
              <td class="px-4 py-3 hidden md:table-cell text-xs text-gray-500">
                <%= ag.requestor_name.presence || '—' %>
              </td>
              <td class="px-4 py-3">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                             <%= { 'draft' => 'bg-gray-100 text-gray-600',
                                   'pending_ig' => 'bg-yellow-100 text-yellow-800',
                                   'sent_counterparty' => 'bg-blue-100 text-blue-800',
                                   'complete' => 'bg-green-100 text-green-800',
                                   'cancelled' => 'bg-red-100 text-red-700' }.fetch(ag.status, 'bg-gray-100 text-gray-600') %>">
                  <%= ag.status_label %>
                </span>
              </td>
              <td class="px-4 py-3 text-right">
                <%= link_to 'View', agreement_path(ag),
                    class: 'text-xs font-medium text-blue-600 hover:text-blue-800' %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="px-5 py-6 text-sm text-gray-400 text-center">No agreements yet with this company.</p>
    <% end %>
  </div>

</div>
