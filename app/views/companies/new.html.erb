<% content_for :title, 'Add Counterparty' %>

<div class="max-w-xl mx-auto px-4 py-8">
  <%= link_to companies_path, class: 'text-xs text-gray-400 hover:text-gray-600 flex items-center gap-1 mb-4' do %>
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5m7-7-7 7 7 7"/></svg>
    Back to Contacts
  <% end %>

  <h1 class="text-xl font-bold text-gray-900 mb-6">Add Counterparty</h1>

  <%= form_with model: @company, url: companies_path, class: 'space-y-4' do |f| %>
    <% if @company.errors.any? %>
      <div class="p-4 rounded-lg bg-red-50 border border-red-200 text-sm text-red-700">
        <% @company.errors.full_messages.each do |msg| %>
          <p>• <%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1.5">Company Name <span class="text-red-500">*</span></label>
      <%= f.text_field :name, class: 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500', placeholder: 'Acme Corp (Pty) Ltd', required: true %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1.5">Registration Number</label>
      <%= f.text_field :registration_number, class: 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500', placeholder: '2001/123456/07' %>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Primary Contact Name</label>
        <%= f.text_field :primary_contact_name, class: 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500', placeholder: 'John Smith' %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Primary Contact Email</label>
        <%= f.email_field :primary_contact_email, class: 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500', placeholder: 'john@acme.co.za' %>
      </div>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1.5">Domain</label>
      <%= f.text_field :domain, class: 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500', placeholder: 'acme.co.za' %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1.5">Address</label>
      <%= f.text_area :address, rows: 2, class: 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none', placeholder: '123 Main St, Cape Town, 8001' %>
    </div>

    <div class="pt-4 flex items-center justify-between border-t border-gray-200">
      <%= link_to 'Cancel', companies_path, class: 'text-sm text-gray-500 hover:text-gray-700' %>
      <%= f.submit 'Add Counterparty', class: 'px-5 py-2.5 rounded-lg text-sm font-semibold text-white cursor-pointer hover:opacity-90', style: 'background-color:#1a2332;' %>
    </div>
  <% end %>
</div>
