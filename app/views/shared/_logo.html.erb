<%#
  IGSIGN Logo Partial — Brand v5 (img-based, clean at all sizes)
  dark:true  → igsign-primary-dark.svg (white on navy, blends into Arctic Black navbar)
  dark:false → igsign-primary-light.svg (navy on white, for light backgrounds)
  tagline:true → show full lockup including tagline
  height → display height in px (default 44)
%>
<%
  dark       = local_assigns.fetch(:dark, false)
  show_tag   = local_assigns.fetch(:tagline, false)
  h          = local_assigns.fetch(:height, '44').to_s.to_i
  src        = dark ? '/brand/igsign-primary-dark.svg' : '/brand/igsign-primary-light.svg'
  # The primary SVGs are 1400x520. Crop viewBox to just icon+wordmark (no tagline)
  # by controlling rendered height — tagline sits below y=330, so at h<=52 it's invisible
%>
<img src="<%= src %>"
     height="<%= h %>"
     alt="IGSIGN — Ignition Group e-Signing Portal"
     style="display:block; max-width:none; flex-shrink:0;">