<%
  dark    = local_assigns.fetch(:dark, false)
  tagline = local_assigns.fetch(:tagline, false)
  h       = local_assigns.fetch(:height, '38').to_s.gsub(/[^0-9]/, '').presence || '38'
  src     = dark ? '/brand/igsign-nav-dark.svg' : '/brand/igsign-wordmark.svg'
  tag_col = dark ? 'rgba(255,255,255,0.5)' : '#7B787F'
%>
<div style="display:inline-block;">
  <img src="<%= src %>" alt="IGSIGN" style="height:<%= h %>px; width:auto; display:block; flex-shrink:0;">
  <% if tagline %>
    <div style="font-size:9px; letter-spacing:3px; text-transform:uppercase; color:<%= tag_col %>; margin-top:5px; font-family:'DM Sans',Avenir,Arial,sans-serif; font-weight:500;">Powered by Possibility</div>
  <% end %>
</div>
