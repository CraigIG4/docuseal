<%= render 'shared/navbar_warning' %>
<%# IGSIGN: Full-width Arctic Black premium navbar %>
<nav class="w-full mb-6 border-b" style="background-color:#162B3C; border-color:#0d1f2d;">
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-0 flex items-center justify-between" style="height:60px;">

    <%# Left: logo + wordmark %>
    <a href="<%= root_path %>" class="flex items-center space-x-0 group" style="text-decoration:none;">
      <%= render 'shared/logo', dark: true, height: '38' %>
    </a>

    <%# Right: nav actions %>
    <% if signed_in? %>
      <div class="flex items-center space-x-4">
        <%# Nav links — hidden on mobile %>
        <div class="hidden md:flex items-center space-x-5">
          <%= render 'shared/navbar_buttons' %>
          <%= link_to t('settings'), settings_profile_index_path,
                class: 'text-sm font-medium transition-colors duration-150',
                style: 'color: rgba(255,255,255,0.75)',
                id: 'account_settings_button' %>
        </div>

        <%# User avatar dropdown %>
        <div class="dropdown dropdown-end">
          <label tabindex="0"
                 class="cursor-pointer flex items-center justify-center rounded-full font-bold text-sm select-none"
                 style="background-color:#45AC34; color:#162B3C; width:34px; height:34px;">
            <%= current_user.initials %>
          </label>
          <ul tabindex="0"
              class="z-50 dropdown-content p-2 mt-2 shadow-xl menu bg-base-100 rounded-xl min-w-[180px]"
              style="border:1px solid #e8ebed;">
            <li>
              <%= link_to settings_profile_index_path, class: 'flex items-center gap-2 text-sm' do %>
                <%= svg_icon('adjustments', class: 'w-4 h-4 flex-shrink-0') %>
                <%= t('profile') %>
              <% end %>
            </li>
            <% if !Docuseal.demo? && can?(:manage, EncryptedConfig) %>
              <li>
                <%= link_to Docuseal.multitenant? ? console_redirect_index_path : Docuseal::CONSOLE_URL,
                      data: { prefetch: false }, class: 'flex items-center gap-2 text-sm' do %>
                  <%= svg_icon('terminal', class: 'w-4 h-4 flex-shrink-0') %>
                  <%= t('console') %>
                <% end %>
              </li>
            <% end %>
            <% if can?(:read, EncryptedConfig.new(key: EncryptedConfig::ESIGN_CERTS_KEY, account: current_account)) %>
              <li>
                <%= link_to settings_esign_path, class: 'flex items-center gap-2 text-sm' do %>
                  <%= svg_icon('zoom_check', class: 'w-4 h-4 flex-shrink-0') %>
                  <%= t('verify_pdf') %>
                <% end %>
              </li>
            <% end %>
            <% if (can?(:manage, EncryptedConfig) && current_user == true_user) || (current_user != true_user && current_account.testing?) %>
              <%= form_for '', url: testing_account_path, method: current_account.testing? ? :delete : :get,
                    html: { class: 'w-full py-1' } do |f| %>
                <label class="flex items-center px-3 py-2 border-y border-base-300 text-sm gap-2" for="testing_toggle">
                  <submit-form data-on="change" class="flex">
                    <%= f.check_box :testing_toggle, class: 'toggle toggle-sm', checked: current_account.testing? %>
                  </submit-form>
                  <%= t('test_mode') %>
                </label>
              <% end %>
            <% end %>
            <li class="border-t border-base-300 mt-1 pt-1">
              <%= button_to destroy_user_session_path, method: :delete,
                    data: { turbo: false }, class: 'flex items-center gap-2 text-sm w-full text-left' do %>
                <%= svg_icon('logout', class: 'w-4 h-4 flex-shrink-0') %>
                <%= t('sign_out') %>
              <% end %>
            </li>
          </ul>
        </div>

        <%# Mobile hamburger placeholder — space for future mobile nav %>
        <button class="md:hidden flex flex-col gap-1 p-1" style="color:#ffffff;" aria-label="Menu">
          <span class="block w-5 h-0.5 bg-white"></span>
          <span class="block w-5 h-0.5 bg-white"></span>
          <span class="block w-5 h-0.5 bg-white"></span>
        </button>
      </div>

    <% else %>
      <%# Unauthenticated: sign-in only — no sign-up noise %>
      <% if request.path != new_user_session_path && request.path != setup_index_path %>
        <%= link_to new_user_session_path({ lang: params[:lang] }.compact_blank),
              class: 'flex items-center gap-1.5 text-sm font-semibold transition-colors duration-150',
              style: 'color:#ffffff;' do %>
          <%= svg_icon('login', class: 'w-5 h-5') %>
          <span><%= t('sign_in') %></span>
        <% end %>
      <% end %>
    <% end %>

  </div>
</nav>