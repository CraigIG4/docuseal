<%# ── Approval Matrices — Admin Index ── %>

<%# Hero header %>
<div style="background:linear-gradient(135deg,#162B3C 0%,#1e3a4f 100%);border-radius:14px;padding:28px 32px;margin-bottom:28px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:url('/brand/igsign-background-pattern.svg');background-size:cover;opacity:0.15;pointer-events:none;border-radius:14px;"></div>
  <div style="position:relative;z-index:1;display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:20px;">
    <div>
      <div style="font-size:11px;color:rgba(255,255,255,0.45);letter-spacing:4px;text-transform:uppercase;margin-bottom:8px;">IGSIGN · LEGAL OPS</div>
      <div style="font-size:22px;font-weight:800;color:#fff;letter-spacing:-0.3px;">Approval Matrices</div>
      <div style="width:36px;height:3px;background:#45AC34;border-radius:2px;margin-top:10px;"></div>
      <div style="font-size:13px;color:rgba(255,255,255,0.55);margin-top:8px;">Define which internal signatories must approve each agreement type before it goes to the counterparty.</div>
    </div>
    <%= link_to new_admin_approval_matrix_path,
          style: 'background:#45AC34;color:#fff;border-radius:8px;padding:12px 20px;font-weight:700;font-size:14px;text-decoration:none;display:flex;align-items:center;gap:8px;white-space:nowrap;align-self:flex-start;' do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
      New Matrix
    <% end %>
  </div>
</div>

<%# Flash %>
<% if notice.present? %>
  <div class="alert alert-success mb-4" role="alert"><%= notice %></div>
<% end %>
<% if alert.present? %>
  <div class="alert alert-error mb-4" role="alert"><%= alert %></div>
<% end %>

<%# Table %>
<div style="background:#fff;border-radius:14px;border:1px solid #edf0f3;overflow:hidden;box-shadow:0 2px 8px rgba(22,43,60,0.06);">
  <% if @matrices.empty? %>
    <div style="padding:60px;text-align:center;">
      <svg xmlns="http://www.w3.org/2000/svg" style="width:48px;height:48px;opacity:0.3;margin:0 auto 16px;" fill="none" viewBox="0 0 24 24" stroke="#162B3C" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75a2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15"/>
      </svg>
      <p style="font-size:16px;font-weight:700;color:#162B3C;">No matrices yet</p>
      <p style="font-size:14px;color:#7B787F;margin-top:4px;">Create your first approval matrix to define signing chains for agreement types.</p>
      <%= link_to '+ New Matrix', new_admin_approval_matrix_path, class: 'btn btn-primary mt-4' %>
    </div>

  <% else %>
    <table class="table w-full" style="border-collapse:collapse;">
      <thead>
        <tr>
          <th>Name</th>
          <th>Agreement Types</th>
          <th>Entity Scope</th>
          <th>Value Threshold</th>
          <th>Stages</th>
          <th>Status</th>
          <th style="text-align:right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @matrices.each do |matrix| %>
          <tr style="border-bottom:1px solid #edf0f3; <%= 'opacity:0.5;' unless matrix.active? %>">
            <td style="padding:12px 16px;font-weight:600;color:#162B3C;">
              <%= matrix.name %>
            </td>
            <td style="padding:12px 16px;">
              <% matrix.agreement_types.each do |t| %>
                <span class="badge badge-primary" style="margin-right:3px;"><%= t.upcase %></span>
              <% end %>
            </td>
            <td style="padding:12px 16px;font-size:13px;color:#7B787F;">
              <%= matrix.entity_scope_label %>
            </td>
            <td style="padding:12px 16px;font-size:13px;color:#162B3C;">
              <% if matrix.value_threshold.present? %>
                ≥ R <%= number_with_delimiter(matrix.value_threshold, delimiter: ',') %>
              <% else %>
                <span style="color:#bbb;">—</span>
              <% end %>
            </td>
            <td style="padding:12px 16px;text-align:center;">
              <span class="badge badge-neutral"><%= matrix.stage_count %></span>
            </td>
            <td style="padding:12px 16px;">
              <% if matrix.active? %>
                <span class="ig-status-active">Active</span>
              <% else %>
                <span class="ig-status-pending">Inactive</span>
              <% end %>
            </td>
            <td style="padding:12px 16px;text-align:right;white-space:nowrap;">
              <%= link_to 'Edit', edit_admin_approval_matrix_path(matrix),
                    class: 'btn btn-sm btn-outline',
                    style: 'margin-right:6px;' %>
              <% if matrix.active? %>
                <%= button_to 'Deactivate',
                      deactivate_admin_approval_matrix_path(matrix),
                      method: :patch,
                      class: 'btn btn-sm',
                      style: 'background:#7B787F;color:#fff;border:none;',
                      data: { confirm: "Deactivate \"#{matrix.name}\"? It will no longer be used for new agreements." } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>

<%# Explanation panel %>
<div class="card mt-6" style="padding:20px 24px;">
  <h3 class="igsign-section-head" style="font-size:14px;margin-bottom:12px;">How resolution works</h3>
  <p style="font-size:13px;color:#7B787F;line-height:1.6;">
    When a new agreement is initiated, IGSIGN picks the <strong>most specific</strong> active matrix for that account.
    Specificity priority: <strong>entity-scoped &gt; all entities</strong>,
    then <strong>value-threshold set &gt; none</strong>,
    then <strong>single agreement type &gt; multiple</strong>.
    If no matrix matches, the agreement falls back to the default IGSIGN signatory chain.
  </p>
</div>
