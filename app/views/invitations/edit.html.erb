<style>
  body { background: #f5f7f9 !important; background-image: none !important; }
</style>

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:40px 16px;">
  <div style="width:100%;max-width:800px;display:flex;gap:28px;align-items:flex-start;flex-wrap:wrap;">

    <%# Password form %>
    <div style="flex:1;min-width:300px;max-width:380px;background:#fff;border-radius:14px;padding:40px 32px;box-shadow:0 4px 24px rgba(22,43,60,0.08);border:1px solid #edf0f3;">
      <div style="margin-bottom:28px;">
        <%= render 'shared/logo', dark: false, height: '32' %>
      </div>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
        <div style="width:8px;height:8px;border-radius:50%;background:#45AC34;flex-shrink:0;"></div>
        <h1 style="font-size:18px;font-weight:800;color:#162B3C;margin:0;">Welcome to IGSIGN</h1>
      </div>
      <p style="font-size:13px;color:#7B787F;margin:0 0 24px;line-height:1.6;">You've been invited. Set a password to activate your account.</p>

      <%= form_for(resource, as: resource_name, url: invitation_path, html: { method: :put }) do |f| %>
        <%= render 'devise/shared/error_messages', resource: resource %>
        <%= f.hidden_field :reset_password_token %>
        <div style="margin-bottom:14px;">
          <label style="font-size:12px;font-weight:600;color:#162B3C;margin-bottom:5px;display:block;letter-spacing:0.2px;">New password</label>
          <%= f.password_field :password, autofocus: true, autocomplete: 'new-password',
              style: 'width:100%;padding:10px 13px;border:1.5px solid #e2e6ea;border-radius:7px;font-size:14px;color:#162B3C;background:#f9fbfc;outline:none;box-sizing:border-box;',
              placeholder: 'Choose a strong password' %>
          <% if @minimum_password_length %>
            <p style="font-size:11px;color:#9aa3ae;margin:4px 0 0;">Minimum <%= @minimum_password_length %> characters</p>
          <% end %>
        </div>
        <div style="margin-bottom:20px;">
          <label style="font-size:12px;font-weight:600;color:#162B3C;margin-bottom:5px;display:block;letter-spacing:0.2px;">Confirm password</label>
          <%= f.password_field :password_confirmation, autocomplete: 'new-password',
              style: 'width:100%;padding:10px 13px;border:1.5px solid #e2e6ea;border-radius:7px;font-size:14px;color:#162B3C;background:#f9fbfc;outline:none;box-sizing:border-box;',
              placeholder: 'Re-enter your password' %>
        </div>
        <%= f.button button_title(title: 'Activate account', disabled_with: 'Activating…'),
            style: 'width:100%;padding:12px;background:#162B3C;color:#fff;border:none;border-radius:7px;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;letter-spacing:0.2px;' %>
      <% end %>

      <div style="margin-top:20px;padding-top:16px;border-top:1px solid #f0f2f5;text-align:center;font-size:10.5px;color:#c0c8d0;letter-spacing:0.3px;">
        ECT Act 25 of 2002 &middot; Ignition Group Internal
      </div>
    </div>

    <%# How-to wizard %>
    <div style="flex:1;min-width:260px;max-width:340px;padding-top:8px;">
      <p style="font-size:10px;color:#9aa3ae;letter-spacing:3px;text-transform:uppercase;margin:0 0 4px;">Getting started</p>
      <h2 style="font-size:16px;font-weight:800;color:#162B3C;margin:0 0 4px;">How IGSIGN works</h2>
      <div style="width:24px;height:2px;background:#45AC34;border-radius:2px;margin-bottom:20px;"></div>

      <div style="display:flex;gap:12px;margin-bottom:14px;">
        <div style="flex-shrink:0;width:28px;height:28px;border-radius:50%;background:#162B3C;color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;margin-top:2px;">1</div>
        <div style="flex:1;background:#fff;border-radius:8px;padding:12px 14px;border:1px solid #edf0f3;box-shadow:0 1px 4px rgba(22,43,60,0.05);">
          <div style="font-size:12px;font-weight:700;color:#162B3C;margin-bottom:3px;">Set your password</div>
          <p style="font-size:11.5px;color:#7B787F;margin:0;line-height:1.55;">Create a secure password to access your personal IGSIGN account.</p>
        </div>
      </div>

      <div style="margin-left:13px;width:2px;height:10px;background:linear-gradient(180deg,#162B3C,#45AC34);margin-bottom:4px;"></div>

      <div style="display:flex;gap:12px;margin-bottom:14px;">
        <div style="flex-shrink:0;width:28px;height:28px;border-radius:50%;background:#162B3C;color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;margin-top:2px;">2</div>
        <div style="flex:1;background:#fff;border-radius:8px;padding:12px 14px;border:1px solid #edf0f3;box-shadow:0 1px 4px rgba(22,43,60,0.05);">
          <div style="font-size:12px;font-weight:700;color:#162B3C;margin-bottom:3px;">Upload a document template</div>
          <p style="font-size:11.5px;color:#7B787F;margin:0;line-height:1.55;">Upload a PDF or Word document and drag signature fields onto it.</p>
        </div>
      </div>

      <div style="margin-left:13px;width:2px;height:10px;background:#45AC34;margin-bottom:4px;"></div>

      <div style="display:flex;gap:12px;margin-bottom:20px;">
        <div style="flex-shrink:0;width:28px;height:28px;border-radius:50%;background:#45AC34;color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;margin-top:2px;">3</div>
        <div style="flex:1;background:#fff;border-radius:8px;padding:12px 14px;border:1px solid #d4f0ce;box-shadow:0 1px 4px rgba(69,172,52,0.07);">
          <div style="font-size:12px;font-weight:700;color:#162B3C;margin-bottom:3px;">Send for signature</div>
          <p style="font-size:11.5px;color:#7B787F;margin:0;line-height:1.55;">Send to signatories by email. Track signing in real time with a full audit trail.</p>
        </div>
      </div>

      <div style="background:#162B3C;border-radius:8px;padding:12px 14px;display:flex;align-items:center;gap:10px;">
        <div style="width:6px;height:6px;border-radius:50%;background:#45AC34;flex-shrink:0;"></div>
        <div style="font-size:11px;color:rgba(255,255,255,0.7);line-height:1.5;">
          <strong style="color:#fff;font-weight:700;">ECT Act 25 of 2002 compliant</strong> &middot;
          Self-hosted &middot; Full audit trail
        </div>
      </div>
    </div>

  </div>
</div>
