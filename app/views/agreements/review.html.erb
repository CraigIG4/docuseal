<% content_for :title, 'Review & Send' %>

<div class="max-w-2xl mx-auto px-4 py-8">

  <%# Step indicator %>
  <div class="flex items-center mb-8">
    <% [['1', 'Agreement Details'], ['2', 'Upload Document'], ['3', 'Review & Send']].each_with_index do |(n, label), i| %>
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold shrink-0
             <%= @step.to_i >= n.to_i ? 'text-white' : 'text-gray-400 border-2 border-gray-200 bg-white' %>"
             style="<%= @step.to_i >= n.to_i ? 'background-color:#1a2332;' : '' %>">
          <%= n %>
        </div>
        <span class="text-sm whitespace-nowrap
             <%= @step.to_i == n.to_i ? 'font-semibold text-gray-900' : 'text-gray-400' %>">
          <%= label %>
        </span>
      </div>
      <% if i < 2 %><div class="flex-1 h-px bg-gray-200 mx-3 min-w-[24px]"></div><% end %>
    <% end %>
  </div>

  <h1 class="text-xl font-bold text-gray-900 mb-1">Review &amp; Send</h1>
  <p class="text-sm text-gray-500 mb-6">Review the signing package before sending for internal approval.</p>

  <%# ── Card 1: Agreement Summary ─────────────────────────────────────────── %>
  <div class="rounded-xl border border-gray-200 bg-white mb-4 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100 flex items-center gap-2" style="background-color:#f8fafc;">
      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/>
      </svg>
      <span class="text-sm font-semibold text-gray-700">Agreement Summary</span>
    </div>
    <div class="px-5 py-4 grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">Type</p>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold text-white"
              style="background-color:#1a2332;">
          <%= @agreement.agreement_type_label %>
        </span>
      </div>
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">IG Entity</p>
        <p class="font-medium text-gray-900"><%= @agreement.entity_name %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">Counterparty</p>
        <p class="font-medium text-gray-900"><%= @agreement.contracting_party.presence || '—' %></p>
        <% if @agreement.counterparty_email.present? %>
          <p class="text-xs text-gray-400"><%= @agreement.counterparty_email %></p>
        <% end %>
      </div>
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">Requestor</p>
        <p class="font-medium text-gray-900"><%= @agreement.requestor_name %></p>
      </div>
      <% if @agreement.mandate_description.present? %>
        <div class="col-span-2">
          <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">Mandate</p>
          <p class="text-gray-700"><%= @agreement.mandate_description %></p>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Card 2: Signing Package ────────────────────────────────────────────── %>
  <div class="rounded-xl border border-gray-200 bg-white mb-4 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100 flex items-center gap-2" style="background-color:#f8fafc;">
      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M19 11H5m14 0a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-6a2 2 0 0 1 2-2m14 0V9a2 2 0 0 0-2-2M5 11V9a2 2 0 0 1 2-2m0 0V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2M7 7h10"/>
      </svg>
      <span class="text-sm font-semibold text-gray-700">Signing Package — Shared with counterparty</span>
    </div>
    <div class="px-5 py-4 space-y-3">
      <%# Document 1: auto-generated CAF (internal only — shown for sender context) %>
      <div class="flex items-start gap-3 p-3 rounded-lg bg-amber-50 border border-amber-200">
        <span class="text-lg leading-none mt-0.5">📋</span>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-gray-900"><%= @agreement.caf_label %></p>
          <p class="text-xs text-gray-500 mt-0.5">Auto-generated from agreement details</p>
        </div>
        <span class="shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
          Internal only
        </span>
      </div>

      <%# Uploaded agreement documents — one card per file %>
      <% if @template_docs.any? %>
        <% @template_docs.each do |att| %>
          <div class="flex items-start gap-3 p-3 rounded-lg bg-gray-50 border border-gray-200">
            <span class="text-lg leading-none mt-0.5">📄</span>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate"><%= att.blob.filename %></p>
              <p class="text-xs text-gray-500 mt-0.5">Sent to counterparty after internal approval</p>
            </div>
            <span class="shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
              Shared with counterparty
            </span>
          </div>
        <% end %>
      <% else %>
        <div class="flex items-center gap-2 p-3 rounded-lg bg-yellow-50 border border-yellow-200 text-sm text-yellow-800">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M12 9v4m0 4h.01M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
          </svg>
          No documents uploaded yet.
          <%= link_to 'Upload one →', upload_agreement_path(@agreement), class: 'font-medium underline' %>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Card 3: Signing Journey ───────────────────────────────────────────── %>
  <div class="rounded-xl border border-gray-200 bg-white mb-4 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100 flex items-center gap-2" style="background-color:#f8fafc;">
      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      <span class="text-sm font-semibold text-gray-700">Signing journey</span>
    </div>
    <div class="px-5 py-5 overflow-x-auto">
      <%= render 'signing_journey',
                 agreement:              @agreement,
                 signatories:            @signatories,
                 mode:                   :preview,
                 counterparty_signatory: @counterparty_signatory %>
    </div>
    <%# Authority note (shown below journey when there's a memorised signatory) %>
    <% if @counterparty_signatory %>
      <div class="px-5 pb-4">
        <% if @counterparty_signatory.authority_on_file? %>
          <p class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
            Authority on file for <%= @counterparty_signatory.name.split.first %>: <%= @counterparty_signatory.authority_basis.truncate(60) %>
          </p>
        <% elsif @agreement.agreement_type.in?(%w[msa sla vendor employment]) %>
          <p class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-200">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
            No authority basis on file for <%= @counterparty_signatory.name.split.first %> —
            verify signing authority for <%= @agreement.contracting_party.presence || 'this company' %>.
          </p>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Submission note %>
  <% first_signer = @signatories.first %>
  <% if first_signer %>
    <p class="text-xs text-gray-500 text-center mb-4">
      By submitting, this agreement will be sent to
      <strong><%= first_signer['name'].presence || first_signer['role'] %></strong>
      for review.
    </p>
  <% end %>

  <%# ECT Act notice %>
  <p class="text-xs text-gray-400 text-center mb-6">
    This agreement will be executed in accordance with the Electronic Communications and Transactions Act 25 of 2002 (SES-grade). All signatures constitute valid electronic signatures.
  </p>

  <%# Actions %>
  <div class="flex items-center justify-between pt-4 border-t border-gray-200">
    <%= link_to position_agreement_path(@agreement), class: 'text-sm text-gray-500 hover:text-gray-700' do %>
      ← Back to Field Placement
    <% end %>

    <div class="flex items-center gap-3">
      <%= link_to caf_preview_agreement_path(@agreement), target: '_blank',
                  class: 'px-4 py-2.5 rounded-lg text-sm font-semibold border border-gray-300 text-gray-600 hover:bg-gray-50 transition-colors' do %>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M7 21h10a2 2 0 0 0 2-2V9.414a1 1 0 0 0-.293-.707l-5.414-5.414A1 1 0 0 0 13 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2z"/>
          </svg>
          Preview CAF
        </span>
      <% end %>
      <% if @agreement.signatories&.any? { |s| s['placeholder'] } %>
        <p class="text-xs text-amber-600">Some signatories need to be assigned before sending.</p>
      <% end %>
      <%= form_with url: send_agreement_agreement_path(@agreement), method: :post do |f| %>
        <%= f.submit 'Send for Internal Approval →',
                     class: 'px-6 py-2.5 rounded-lg text-sm font-semibold text-white cursor-pointer transition-colors hover:opacity-90',
                     style: 'background-color:#45AC34;' %>
      <% end %>
    </div>
  </div>

</div>
