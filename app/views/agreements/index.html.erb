<% content_for :title, 'Agreements' %>

<div class="max-w-5xl mx-auto px-4 py-8">

  <%# ── Header ──────────────────────────────────────────────────────────────── %>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Agreements</h1>
      <p class="text-sm text-gray-400 mt-0.5">All agreements across Ignition Group entities</p>
    </div>
    <%= link_to new_agreement_path,
          class: 'flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-semibold text-white transition-colors hover:opacity-90',
          style: 'background-color:#1a2332;' do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M12 5v14M5 12h14"/>
      </svg>
      New Agreement
    <% end %>
  </div>

  <%# ── Stats bar ────────────────────────────────────────────────────────────── %>
  <div class="grid grid-cols-4 gap-4 mb-6">
    <% [
      { label: 'Total',    count: @stats[:total],    color: '#1a2332' },
      { label: 'Draft',    count: @stats[:draft],    color: '#9ca3af' },
      { label: 'Active',   count: @stats[:active],   color: '#d97706' },
      { label: 'Complete', count: @stats[:complete], color: '#16a34a' }
    ].each do |s| %>
      <div class="rounded-xl border border-gray-200 bg-white px-4 py-3">
        <p class="text-2xl font-bold" style="color:<%= s[:color] %>;"><%= s[:count] %></p>
        <p class="text-xs text-gray-400 mt-0.5"><%= s[:label] %></p>
      </div>
    <% end %>
  </div>

  <%# ── Filter tabs ──────────────────────────────────────────────────────────── %>
  <div class="flex items-center gap-1 mb-4 border-b border-gray-200">
    <% [['', 'All'], ['draft', 'Draft'], ['pending_ig', 'Pending IG'], ['sent_counterparty', 'With Counterparty'], ['complete', 'Complete']].each do |val, label| %>
      <% is_active = params[:status].to_s == val %>
      <%= link_to agreements_path(status: val.presence),
            class: "px-3 py-2 text-sm font-medium border-b-2 transition-colors -mb-px
              #{is_active ? 'border-gray-900 text-gray-900' : 'border-transparent text-gray-400 hover:text-gray-700'}" do %>
        <%= label %>
      <% end %>
    <% end %>
  </div>

  <%# ── Table ───────────────────────────────────────────────────────────────── %>
  <% if @agreements.any? %>
    <div class="rounded-xl border border-gray-200 bg-white overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200" style="background-color:#f8fafc;">
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Type</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Counterparty</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide hidden md:table-cell">Entity</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide hidden md:table-cell">Date</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @agreements.each do |a| %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-4 py-3">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold text-white"
                      style="background-color:#1a2332;">
                  <%= a.agreement_type_label.split(' — ').first %>
                </span>
              </td>
              <td class="px-4 py-3">
                <p class="font-medium text-gray-900 truncate max-w-[180px]">
                  <%= a.contracting_party.presence || '—' %>
                </p>
                <% if a.company %>
                  <p class="text-xs text-gray-400 truncate"><%= a.company.name %></p>
                <% end %>
              </td>
              <td class="px-4 py-3 hidden md:table-cell text-gray-600 text-xs">
                <%= a.entity_name %>
              </td>
              <td class="px-4 py-3">
                <span class="badge <%= a.status_badge_class %> badge-sm whitespace-nowrap">
                  <%= a.status_label %>
                </span>
              </td>
              <td class="px-4 py-3 hidden md:table-cell text-gray-400 text-xs whitespace-nowrap">
                <%= a.created_at.strftime('%d %b %Y') %>
              </td>
              <td class="px-4 py-3 text-right">
                <% if a.draft? %>
                  <%= link_to 'Continue →', upload_agreement_path(a),
                        class: 'text-xs font-medium text-blue-600 hover:text-blue-800' %>
                <% else %>
                  <%= link_to 'View →', agreement_path(a),
                        class: 'text-xs font-medium text-blue-600 hover:text-blue-800' %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="rounded-xl border-2 border-dashed border-gray-200 py-16 text-center">
      <svg class="w-12 h-12 text-gray-200 mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z"/>
      </svg>
      <p class="text-gray-500 font-medium mb-1">No agreements yet</p>
      <p class="text-sm text-gray-400 mb-4">Create your first agreement to get started.</p>
      <%= link_to 'Create Agreement →', new_agreement_path,
            class: 'inline-flex items-center px-4 py-2 rounded-lg text-sm font-semibold text-white',
            style: 'background-color:#1a2332;' %>
    </div>
  <% end %>

</div>
