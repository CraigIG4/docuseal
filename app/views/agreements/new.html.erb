<% content_for :title, 'New Agreement' %>
<div class="max-w-5xl mx-auto px-4 py-8">
  <div style="display:flex;align-items:center;margin-bottom:2rem;">
    <% [['1', 'Agreement Details'], ['2', 'Upload Document'], ['3', 'Review & Send']].each_with_index do |(n, label), i| %>
      <div style="display:flex;align-items:center;gap:8px;">
        <div style="width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;background-color:<%= @step.to_i >= n.to_i ? '#162B3C' : 'white' %>;color:<%= @step.to_i >= n.to_i ? 'white' : '#9ca3af' %>;border:<%= @step.to_i >= n.to_i ? 'none' : '2px solid #e5e7eb' %>;"><%= n %></div>
        <span style="font-size:14px;white-space:nowrap;font-weight:<%= @step.to_i == n.to_i ? '600' : '400' %>;color:<%= @step.to_i == n.to_i ? '#111827' : '#9ca3af' %>;"><%= label %></span>
      </div>
      <% if i < 2 %><div style="flex:1;height:1px;background:#e5e7eb;margin:0 12px;min-width:24px;"></div><% end %>
    <% end %>
  </div>
  <h1 style="font-size:1.5rem;font-weight:700;color:#111827;margin-bottom:4px;">New Agreement</h1>
  <p style="font-size:14px;color:#6b7280;margin-bottom:1.5rem;">Signatories are assigned automatically based on entity and agreement type.</p>
  <%= form_with scope: :agreement, url: agreements_path, method: :post, html: { id: 'agwiz' } do |f| %>
    <% if @agreement.errors.any? %>
      <div style="margin-bottom:1rem;padding:1rem;border-radius:8px;background:#fef2f2;border:1px solid #fecaca;font-size:14px;color:#b91c1c;">
        <% @agreement.errors.full_messages.each do |msg| %><p>&bull; <%= msg %></p><% end %>
      </div>
    <% end %>
    <div style="display:grid;gap:1.25rem;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div>
          <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:5px;">Agreement Type <span style="color:#ef4444">*</span></label>
          <%= f.select :agreement_type, CafWorkflow::AGREEMENT_TYPES.map { |k, v| [v, k] }, { include_blank: '-- Select type --' }, id: 'ag_type', style: 'width:100%;border-radius:8px;border:1px solid #d1d5db;padding:9px 12px;font-size:14px;background:white;', required: true %>
        </div>
        <div>
          <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:5px;">IG Entity <span style="color:#ef4444">*</span></label>
          <%= f.select :entity, IgSignatories::ENTITIES.map { |k, v| [v[:name], k.to_s] }, { include_blank: '-- Select entity --' }, id: 'ag_entity', style: 'width:100%;border-radius:8px;border:1px solid #d1d5db;padding:9px 12px;font-size:14px;background:white;', required: true %>
        </div>
      </div>
      <div id="entity_panel" style="display:none;border-radius:10px;border:1px solid #dbeafe;background:#eff6ff;padding:1rem;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div>
            <p style="font-size:11px;font-weight:700;color:#3b82f6;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px;">Entity Details</p>
            <p id="ep_name" style="font-size:14px;font-weight:700;color:#1e3a5f;margin-bottom:3px;"></p>
            <p id="ep_reg"  style="font-size:12px;color:#4b5563;margin-bottom:4px;"></p>
            <p id="ep_addr" style="font-size:12px;color:#4b5563;white-space:pre-line;line-height:1.5;"></p>
          </div>
          <div>
            <p style="font-size:11px;font-weight:700;color:#3b82f6;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px;">Signing Chain <span id="ep_ct" style="font-weight:400;text-transform:none;color:#6b7280;"></span></p>
            <div id="ep_chain" style="font-size:12px;color:#374151;line-height:2;"></div>
          </div>
        </div>
        <div style="margin-top:8px;border-top:1px solid #bfdbfe;padding-top:6px;display:flex;gap:8px;align-items:center;">
          <button type="button" id="ep_copy" style="font-size:11px;color:#3b82f6;background:none;border:1px solid #93c5fd;border-radius:6px;padding:3px 10px;cursor:pointer;">Copy entity details</button>
          <span id="ep_ok" style="font-size:11px;color:#16a34a;display:none;">Copied &#10003;</span>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div>
          <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:5px;">Counterparty Contact Name</label>
          <%= f.text_field :counterparty_name, id: 'ag_ct_name', autocomplete: 'off', style: 'width:100%;border-radius:8px;border:1px solid #d1d5db;padding:9px 12px;font-size:14px;box-sizing:border-box;', placeholder: 'John Smith' %>
        </div>
        <div>
          <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:5px;">Counterparty Contact Email</label>
          <%= f.email_field :counterparty_email, id: 'ag_ct_email', autocomplete: 'email', style: 'width:100%;border-radius:8px;border:1px solid #d1d5db;padding:9px 12px;font-size:14px;box-sizing:border-box;', placeholder: 'john@company.co.za' %>
        </div>
      </div>
      <div>
        <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:5px;">Mandate &amp; Purpose</label>
        <%= f.text_area :mandate_description, rows:3, style:'width:100%;border-radius:8px;border:1px solid #d1d5db;padding:9px 12px;font-size:14px;resize:none;box-sizing:border-box;', placeholder:'Briefly describe what this agreement covers and why it is needed.' %>
      </div>
      <%= f.hidden_field :requestor_name,  value: @agreement.requestor_name %>
      <%= f.hidden_field :requestor_email, value: @agreement.requestor_email %>
      <div style="border-radius:10px;border:1px solid #e5e7eb;background:#f9fafb;padding:1rem;">
        <p style="font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:10px;">Counterparty Company</p>
        <div style="display:grid;grid-template-columns:1fr auto;gap:10px;align-items:flex-start;">
          <div>
            <div style="position:relative;margin-bottom:8px;">
              <input type="text" id="co_search" placeholder="Search existing companies..." autocomplete="off" style="width:100%;border-radius:8px;border:1px solid #d1d5db;background:white;padding:9px 12px 9px 32px;font-size:13px;box-sizing:border-box;">
              <svg style="position:absolute;left:10px;top:10px;width:14px;height:14px;color:#9ca3af;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            </div>
            <div id="co_results" style="display:none;margin-bottom:8px;max-height:160px;overflow-y:auto;border-radius:8px;border:1px solid #e5e7eb;background:white;"></div>
            <div id="co_sel" style="display:none;border-radius:8px;border:1px solid #bfdbfe;background:#eff6ff;padding:10px 12px;margin-bottom:4px;">
              <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
                <div><p id="co_sel_name" style="font-size:13px;font-weight:600;color:#111827;"></p><p id="co_sel_domain" style="font-size:11px;color:#6b7280;margin-top:1px;"></p></div>
                <button type="button" id="co_clear" style="color:#9ca3af;background:none;border:none;cursor:pointer;font-size:20px;line-height:1;padding:0;">&times;</button>
              </div>
            </div>
            <%= f.hidden_field :company_id, id:'co_id' %>
          </div>
          <button type="button" id="co_new_btn" style="border-radius:8px;border:1px dashed #d1d5db;padding:9px 14px;font-size:12px;font-weight:500;color:#6b7280;background:none;cursor:pointer;white-space:nowrap;">+ Add new company</button>
        </div>
        <div id="co_new_form" style="display:none;margin-top:10px;border-top:1px solid #e5e7eb;padding-top:10px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <input type="text" name="new_company_name" autocomplete="organization" placeholder="Company name *" style="border-radius:8px;border:1px solid #d1d5db;padding:8px 12px;font-size:13px;">
            <input type="text" name="new_company_registration_number" autocomplete="off" placeholder="Reg number" style="border-radius:8px;border:1px solid #d1d5db;padding:8px 12px;font-size:13px;">
            <input type="text" name="new_company_contact_name" id="nc_name" autocomplete="name" placeholder="Contact name" style="border-radius:8px;border:1px solid #d1d5db;padding:8px 12px;font-size:13px;">
            <input type="email" name="new_company_contact_email" id="nc_email" autocomplete="email" placeholder="Contact email" style="border-radius:8px;border:1px solid #d1d5db;padding:8px 12px;font-size:13px;">
            <input type="text" name="new_company_domain" autocomplete="off" placeholder="Domain (e.g. acme.co.za)" style="border-radius:8px;border:1px solid #d1d5db;padding:8px 12px;font-size:13px;">
          </div>
          <p style="margin-top:6px;font-size:11px;color:#9ca3af;">Saved to your counterparty directory.</p>
        </div>
      </div>
    </div>
    <div style="margin-top:2rem;display:flex;align-items:center;justify-content:space-between;padding-top:1.5rem;border-top:1px solid #e5e7eb;">
      <%= link_to agreements_path, style: 'font-size:14px;color:#6b7280;text-decoration:none;' do %>&larr; Cancel<% end %>
      <%= f.submit 'Continue to Upload &rarr;', style: 'padding:10px 24px;border-radius:8px;font-size:14px;font-weight:600;color:white;background-color:#162B3C;cursor:pointer;border:none;' %>
    </div>
  <% end %>
</div>
<script>
(function(){
  var E=<%= raw IgSignatories.entities_for_js.to_json %>;
  var C={};
  <% IgSignatories::ENTITIES.each do |key, _| %><% %w[nda short_form long_form].each do |ct| %>C['<%= key %>_<%= ct %>']=<%= raw IgSignatories.chain_for(ct, key)[:stage1].to_json %>;<% end %><% end %>
  var M={nda:'nda',msa:'long_form',sla:'long_form',vendor_agreement:'long_form',other:'long_form',addendum:'short_form',employment_contract:'short_form',policy_acknowledgement:'short_form'};
  var SEARCH='<%= search_companies_agreements_path(format: :json) %>';
  var typeSel=document.getElementById('ag_type'),entSel=document.getElementById('ag_entity'),panel=document.getElementById('entity_panel');
  function updatePanel(){
    var ek=entSel&&entSel.value;if(!ek){panel.style.display='none';return;}
    var e=E.find(function(x){return x.key===ek;});if(!e){panel.style.display='none';return;}
    document.getElementById('ep_name').textContent=e.name;
    document.getElementById('ep_reg').textContent=e.registration?'Reg: '+e.registration:'';
    document.getElementById('ep_addr').textContent=e.address||'';
    var at=typeSel?typeSel.value:'',ct=M[at]||'long_form';
    document.getElementById('ep_ct').textContent={nda:'(NDA)',short_form:'(Short-form)',long_form:'(Long-form)'}[ct]||'';
    var chain=C[ek+'_'+ct]||[];
    document.getElementById('ep_chain').innerHTML=chain.length?chain.map(function(p,i){return'<span style="display:flex;align-items:center;gap:6px;margin-bottom:1px;"><span style="width:18px;height:18px;border-radius:50%;background:#162B3C;color:white;font-size:10px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">'+(i+1)+'</span><strong>'+p.name+'</strong>&nbsp;<span style="color:#6b7280;">'+p.title+'</span></span>';}).join(''):'<span style="color:#9ca3af">Select agreement type to see chain</span>';
    panel.style.display='block';
    document.getElementById('ep_copy').onclick=function(){if(navigator.clipboard){navigator.clipboard.writeText(e.name+'\nReg: '+e.registration+'\n'+e.address).then(function(){var ok=document.getElementById('ep_ok');ok.style.display='inline';setTimeout(function(){ok.style.display='none';},2000);});}};
  }
  entSel&&entSel.addEventListener('change',updatePanel);
  typeSel&&typeSel.addEventListener('change',updatePanel);
  var si=document.getElementById('co_search'),rb=document.getElementById('co_results'),sb=document.getElementById('co_sel'),ci=document.getElementById('co_id'),cn=document.getElementById('ag_ct_name'),ce=document.getElementById('ag_ct_email');
  var dbt;
  si&&si.addEventListener('input',function(){clearTimeout(dbt);dbt=setTimeout(function(){var q=si.value.trim();if(q.length<1){rb.style.display='none';return;}fetch(SEARCH+'?q='+encodeURIComponent(q),{headers:{Accept:'application/json'}}).then(function(r){return r.json();}).then(function(cs){rb.innerHTML='';if(!cs.length){rb.innerHTML='<p style="font-size:12px;color:#9ca3af;padding:8px 12px;">No matches - add below</p>';}else{cs.forEach(function(c){var b=document.createElement('button');b.type='button';b.style.cssText='width:100%;text-align:left;padding:8px 12px;font-size:13px;background:none;border:none;border-bottom:1px solid #f3f4f6;cursor:pointer;';b.onmouseover=function(){this.style.background='#eff6ff';};b.onmouseout=function(){this.style.background='none';};b.innerHTML='<strong style="color:#111827;">'+c.name+'</strong>'+(c.domain?' <span style="font-size:11px;color:#9ca3af;">'+c.domain+'</span>':'')+(c.contact_name?'<br><span style="font-size:11px;color:#6b7280;">'+c.contact_name+'</span>':'');b.addEventListener('click',function(){selC(c);});rb.appendChild(b);});}rb.style.display='block';});},250);});
  function selC(c){ci.value=c.id;document.getElementById('co_sel_name').textContent=c.name;document.getElementById('co_sel_domain').textContent=c.domain||'';sb.style.display='block';rb.style.display='none';si.value='';if(cn&&!cn.value&&c.contact_name)cn.value=c.contact_name;if(ce&&!ce.value&&c.contact_email)ce.value=c.contact_email;}
  var clr=document.getElementById('co_clear');clr&&clr.addEventListener('click',function(){ci.value='';sb.style.display='none';});
  var nb=document.getElementById('co_new_btn'),nf=document.getElementById('co_new_form');
  nb&&nb.addEventListener('click',function(){var h=nf.style.display!=='block';nf.style.display=h?'block':'none';nb.textContent=h?'- Hide form':'+ Add new company';});
  var ncn=document.getElementById('nc_name'),nce=document.getElementById('nc_email');
  ncn&&ncn.addEventListener('input',function(){if(cn&&!cn.value)cn.value=ncn.value;});
  nce&&nce.addEventListener('input',function(){if(ce&&!ce.value)ce.value=nce.value;});
  document.addEventListener('click',function(e){if(rb&&si&&!si.contains(e.target)&&!rb.contains(e.target))rb.style.display='none';});
})();
</script>
