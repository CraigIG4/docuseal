<% content_for :title, 'Upload Document' %>

<div class="max-w-2xl mx-auto px-4 py-8">

  <%# Step indicator %>
  <div class="flex items-center mb-8">
    <% [['1','Agreement Details'],['2','Upload Document'],['3','Review & Send']].each_with_index do |(n,label),i| %>
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold shrink-0
             <%= @step.to_i >= n.to_i ? 'text-white' : 'text-gray-400 border-2 border-gray-200 bg-white' %>"
             style="<%= @step.to_i >= n.to_i ? 'background-color:#1a2332;' : '' %>">
          <%= n %>
        </div>
        <span class="text-sm whitespace-nowrap
             <%= @step.to_i == n.to_i ? 'font-semibold text-gray-900' : 'text-gray-400' %>">
          <%= label %>
        </span>
      </div>
      <% if i < 2 %><div class="flex-1 h-px bg-gray-200 mx-3 min-w-[24px]"></div><% end %>
    <% end %>
  </div>

  <%# Summary of step 1 %>
  <div class="rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 mb-6 flex items-center gap-3">
    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold text-white"
          style="background-color:#1a2332;">
      <%= @agreement.agreement_type_label %>
    </span>
    <span class="text-sm text-gray-700 font-medium"><%= @agreement.contracting_party.presence || '(counterparty pending)' %></span>
    <span class="text-gray-300">·</span>
    <span class="text-sm text-gray-500"><%= @agreement.entity_name %></span>
  </div>

  <h1 class="text-xl font-bold text-gray-900 mb-1">Upload Agreement Document</h1>
  <p class="text-sm text-gray-500 mb-6">Upload the agreement. IGSIGN will automatically detect signature, date, and initial fields.</p>

  <%= form_with url: upload_agreement_path(@agreement), method: :post,
                multipart: true, id: 'upload_form' do |f| %>

    <%# Drop zone %>
    <div id="dropzone"
         class="rounded-xl border-2 border-dashed border-gray-300 bg-gray-50 flex flex-col items-center justify-center text-center py-14 px-6 cursor-pointer transition-colors hover:border-blue-400 hover:bg-blue-50 mb-4"
         onclick="document.getElementById('file_input').click()">
      <svg class="w-12 h-12 text-gray-300 mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5"/>
      </svg>
      <p class="text-sm font-semibold text-gray-700 mb-1">Drop your document here or click to browse</p>
      <p class="text-xs text-gray-400">PDF, Word (.docx), Excel (.xlsx) — Word and Excel are automatically converted to PDF</p>
      <p id="file_name_display" class="mt-3 text-sm font-medium text-blue-600 hidden"></p>
    </div>

    <input type="file"
           id="file_input"
           name="file"
           accept=".pdf,.doc,.docx,.xls,.xlsx,.odt,.rtf"
           class="hidden"
           onchange="handleFileSelect(this)">

    <%# Field detection info %>
    <div class="rounded-lg border border-blue-100 bg-blue-50 p-4 mb-6">
      <div class="flex gap-3">
        <svg class="w-5 h-5 text-blue-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>
        </svg>
        <div>
          <p class="text-sm font-semibold text-blue-800 mb-0.5">Automatic Field Detection</p>
          <p class="text-xs text-blue-600">IGSIGN uses AI to locate where signatures, dates, and initials should be placed in your document. You can adjust or add fields manually before sending.</p>
        </div>
      </div>
    </div>

    <%# CAF note %>
    <div class="rounded-lg border border-amber-100 bg-amber-50 p-4 mb-6">
      <div class="flex gap-3">
        <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
        </svg>
        <div>
          <p class="text-sm font-semibold text-amber-800 mb-0.5"><%= @agreement.caf_label %> — Auto-generated</p>
          <p class="text-xs text-amber-700">A <%= @agreement.caf_label %> will be automatically generated as the first document in the signing package. IG signatories will review and sign the CAF before the agreement is sent to the counterparty.</p>
        </div>
      </div>
    </div>

    <div id="upload_actions" class="flex items-center justify-between pt-4 border-t border-gray-200">
      <%= link_to new_agreement_path, class: 'text-sm text-gray-500 hover:text-gray-700' do %>
        ← Back to Details
      <% end %>
      <button type="submit"
              id="submit_btn"
              disabled
              class="px-6 py-2.5 rounded-lg text-sm font-semibold text-white opacity-40 cursor-not-allowed transition-all"
              style="background-color:#1a2332;">
        <span id="submit_label">Detect Fields &amp; Continue →</span>
      </button>
    </div>

  <% end %>

</div>

<script>
function handleFileSelect(input) {
  const file = input.files[0];
  if (!file) return;
  const display = document.getElementById('file_name_display');
  const btn     = document.getElementById('submit_btn');
  const zone    = document.getElementById('dropzone');
  display.textContent = '📎 ' + file.name + ' (' + (file.size / 1024).toFixed(0) + ' KB)';
  display.classList.remove('hidden');
  zone.classList.add('border-blue-400', 'bg-blue-50');
  zone.classList.remove('border-gray-300', 'bg-gray-50');
  btn.disabled = false;
  btn.classList.remove('opacity-40', 'cursor-not-allowed');
  btn.classList.add('hover:opacity-90', 'cursor-pointer');
}

// Drag-and-drop
document.addEventListener('DOMContentLoaded', function() {
  const zone  = document.getElementById('dropzone');
  const input = document.getElementById('file_input');
  if (!zone || !input) return;

  ['dragenter','dragover'].forEach(e => zone.addEventListener(e, ev => {
    ev.preventDefault();
    zone.classList.add('border-blue-400','bg-blue-50');
  }));
  ['dragleave','drop'].forEach(e => zone.addEventListener(e, ev => {
    ev.preventDefault();
    zone.classList.remove('border-blue-400','bg-blue-50');
  }));
  zone.addEventListener('drop', function(ev) {
    ev.preventDefault();
    if (ev.dataTransfer.files.length) {
      input.files = ev.dataTransfer.files;
      handleFileSelect(input);
    }
  });

  // Show spinner on submit
  document.getElementById('upload_form').addEventListener('submit', function() {
    const label = document.getElementById('submit_label');
    if (label) label.textContent = 'Processing… this may take a moment';
  });
});
</script>
