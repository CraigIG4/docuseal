<title>
  <%= content_for(:html_title) || (signed_in? ? 'IGSIGN | Ignition Group' : 'IGSIGN | Ignition Group e-Signing Portal') %>
</title>
<%# IGSIGN: DM Sans — closest web-safe substitute for Avenir (Ignition Group brand font) %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&display=swap" rel="stylesheet">
<%# IGSIGN brand favicon — replaces IGSIGN default %>
<link rel="icon" type="image/svg+xml" href="/brand/igsign-favicon.svg">
<link rel="apple-touch-icon" href="/brand/igsign-app-icon.svg">
<meta name="theme-color" content="#162B3C">
<%= render 'shared/meta' %>
