<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Signature Reminder — IGSIGN</title>
</head>
<body style="margin:0;padding:0;background:#f5f7fa;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f5f7fa;padding:32px 0;">
    <tr><td align="center">
      <table width="600" cellpadding="0" cellspacing="0" style="background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 4px 16px rgba(22,43,60,0.1);">

        <%# ── Header ── %>
        <tr>
          <td style="background:linear-gradient(135deg,#162B3C 0%,#1e3a4f 100%);padding:28px 40px;">
            <table width="100%" cellpadding="0" cellspacing="0">
              <tr>
                <td>
                  <div style="font-size:11px;color:rgba(255,255,255,0.45);letter-spacing:4px;text-transform:uppercase;margin-bottom:6px;">IGSIGN · ACTION REQUIRED</div>
                  <div style="font-size:20px;font-weight:800;color:#fff;">
                    <% if @days_outstanding >= 9 %>
                      Urgent: Your Signature is Overdue
                    <% elsif @days_outstanding >= 5 %>
                      Action Required: Please Sign
                    <% else %>
                      Friendly Reminder to Sign
                    <% end %>
                  </div>
                  <div style="width:32px;height:3px;background:#f59e0b;border-radius:2px;margin-top:10px;"></div>
                </td>
                <td align="right" style="vertical-align:middle;">
                  <div style="width:48px;height:48px;background:#f59e0b;border-radius:10px;display:inline-flex;align-items:center;justify-content:center;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                  </div>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <%# ── Body ── %>
        <tr>
          <td style="padding:32px 40px;">
            <p style="font-size:15px;color:#162B3C;margin:0 0 16px;">Dear <%= @submitter.name %>,</p>

            <p style="font-size:14px;color:#4a5568;line-height:1.7;margin:0 0 20px;">
              <% if @days_outstanding >= 9 %>
                This agreement has been waiting for your signature for <strong style="color:#dc2626;"><%= @days_outstanding %> days</strong>.
                The workflow cannot progress until you sign. Please take action immediately.
              <% elsif @days_outstanding >= 5 %>
                This agreement has been waiting for your signature for <strong style="color:#d97706;"><%= @days_outstanding %> days</strong>.
                Please sign at your earliest convenience to avoid further delays.
              <% else %>
                You have a document waiting for your signature. Please take a moment to review and sign the agreement below.
              <% end %>
            </p>

            <%# Agreement summary card %>
            <% if @caf %>
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;margin-bottom:28px;">
                <tr>
                  <td style="padding:18px 22px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="padding:5px 0;border-bottom:1px solid #edf0f3;">
                          <span style="font-size:11px;color:#7B787F;font-weight:600;text-transform:uppercase;letter-spacing:0.8px;">Agreement</span>
                          <span style="font-size:13px;color:#162B3C;font-weight:700;float:right;"><%= @caf.agreement_type_label %></span>
                        </td>
                      </tr>
                      <tr>
                        <td style="padding:5px 0;border-bottom:1px solid #edf0f3;">
                          <span style="font-size:11px;color:#7B787F;font-weight:600;text-transform:uppercase;letter-spacing:0.8px;">Counterparty</span>
                          <span style="font-size:13px;color:#162B3C;font-weight:700;float:right;"><%= @caf.contracting_party %></span>
                        </td>
                      </tr>
                      <tr>
                        <td style="padding:5px 0;">
                          <span style="font-size:11px;color:#7B787F;font-weight:600;text-transform:uppercase;letter-spacing:0.8px;">Your Role</span>
                          <span style="font-size:13px;color:#162B3C;font-weight:700;float:right;"><%= @css.role %></span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            <% end %>

            <%# CTA button %>
            <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:24px;">
              <tr>
                <td align="center">
                  <a href="<%= @signing_url %>"
                     style="display:inline-block;background:<%= @days_outstanding >= 9 ? '#dc2626' : '#162B3C' %>;color:white;font-size:15px;font-weight:700;text-decoration:none;padding:14px 36px;border-radius:8px;">
                    Sign Document →
                  </a>
                </td>
              </tr>
            </table>

            <p style="font-size:12px;color:#9ca3af;line-height:1.6;margin:0;">
              If the button doesn't work, copy and paste this link into your browser:<br>
              <a href="<%= @signing_url %>" style="color:#45AC34;word-break:break-all;"><%= @signing_url %></a>
            </p>
          </td>
        </tr>

        <%# ── Footer ── %>
        <tr>
          <td style="background:#f8fafc;border-top:1px solid #edf0f3;padding:18px 40px;text-align:center;">
            <p style="font-size:11px;color:#9aa3ae;margin:0;">
              This reminder was sent by <strong style="color:#162B3C;">IGSIGN</strong> — Ignition Group's internal contract management platform.
              &nbsp;·&nbsp; <a href="https://sign.ignitiongroup.co.za" style="color:#45AC34;text-decoration:none;">sign.ignitiongroup.co.za</a>
            </p>
          </td>
        </tr>

      </table>
    </td></tr>
  </table>
</body>
</html>
