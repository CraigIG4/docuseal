<% if @body.present? %>
  <%# Admin-configured custom body — render as-is and add link if not already present %>
  <%= render 'custom_content', content: @body, submitter: @submitter %>
  <% if !@body.match?(ReplaceEmailVariables::SUBMITTER_LINK) && !@body.match?(ReplaceEmailVariables::SUBMITTER_ID) && !@body.match?(ReplaceEmailVariables::SUBMISSION_LINK) && !@body.match?(ReplaceEmailVariables::TEMPLATE_ID) && !@submitter.submission.source.in?(%w[api embed]) %>
    <p><%= link_to nil, submit_form_url(slug: @submitter.slug, t: SubmissionEvents.build_tracking_param(@submitter, 'click_email'), host: @custom_domain || ENV.fetch('EMAIL_HOST', Docuseal.default_url_options[:host])) %></p>
  <% end %>
<% else %>
<%
  requestor       = @submitter.submission.created_by_user || @submitter.submission.template&.author
  requestor_name  = requestor&.full_name.presence || @current_account.name
  requestor_email = requestor&.email.presence || 'legal@ignitiongroup.co.za'
  submission_name = @submitter.submission.name.presence || @submitter.submission.template.name
  recipient_first = @submitter.name.presence&.split&.first || 'there'
  sign_url = submit_form_url(
    slug: @submitter.slug,
    t:    SubmissionEvents.build_tracking_param(@submitter, 'click_email'),
    host: @custom_domain || ENV.fetch('EMAIL_HOST', Docuseal.default_url_options[:host])
  )
%>

<!-- ============================================================
     IGSIGN Invitation Email — counterparty-facing, brand-critical
     Inline styles throughout for Gmail/Outlook compatibility
     ============================================================ -->

<!-- Greeting -->
<p style="margin:0 0 20px; font-size:15px; line-height:1.6; color:#162B3C;">
  Hi <%= recipient_first %>,
</p>

<!-- Hero card — agreement details -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 24px;">
  <tr>
    <td style="background:#f5f7f9; border:1px solid #e8ebed; border-left:4px solid #45AC34; border-radius:8px; padding:20px 24px;">
      <!-- Agreement label -->
      <p style="margin:0 0 4px; font-size:11px; font-weight:700; color:#7B787F; letter-spacing:0.08em; text-transform:uppercase;">Agreement</p>
      <p style="margin:0 0 16px; font-size:17px; font-weight:700; color:#162B3C; line-height:1.3;">
        <%= submission_name %>
      </p>
      <!-- Sent by -->
      <p style="margin:0 0 4px; font-size:11px; font-weight:700; color:#7B787F; letter-spacing:0.08em; text-transform:uppercase;">Sent by</p>
      <p style="margin:0; font-size:14px; color:#162B3C;">
        <%= requestor_name %> &middot; <%= @current_account.name %>
      </p>
    </td>
  </tr>
</table>

<!-- Primary CTA button — table-based for Outlook -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 28px;">
  <tr>
    <td align="center">
      <table cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td style="background:#162B3C; border-radius:8px; padding:0;">
            <a href="<%= sign_url %>"
               target="_blank"
               style="display:inline-block; background:#162B3C; color:#ffffff !important; text-decoration:none; font-size:15px; font-weight:700; letter-spacing:0.3px; padding:15px 40px; border-radius:8px; font-family:Arial,sans-serif;">
              Review and sign &rarr;
            </a>
          </td>
        </tr>
      </table>
      <p style="margin:10px 0 0; font-size:11px; color:#9aa3ae;">
        This link is unique to you. Do not share it.
      </p>
    </td>
  </tr>
</table>

<!-- What you'll need -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 24px;">
  <tr>
    <td style="background:#ffffff; border:1px solid #e8ebed; border-radius:8px; padding:18px 24px;">
      <p style="margin:0 0 12px; font-size:13px; font-weight:700; color:#162B3C; letter-spacing:0.02em; text-transform:uppercase;">What you'll need</p>
      <table cellpadding="0" cellspacing="0" border="0" width="100%">
        <tr>
          <td style="padding:4px 0; font-size:14px; color:#4a4a4a; vertical-align:top; width:28px;">📱</td>
          <td style="padding:4px 0; font-size:14px; color:#4a4a4a;">A phone or computer — no app required</td>
        </tr>
        <tr>
          <td style="padding:4px 0; font-size:14px; color:#4a4a4a; vertical-align:top;">⏱</td>
          <td style="padding:4px 0; font-size:14px; color:#4a4a4a;">About 5 minutes to review and sign</td>
        </tr>
        <tr>
          <td style="padding:4px 0; font-size:14px; color:#4a4a4a; vertical-align:top;">📄</td>
          <td style="padding:4px 0; font-size:14px; color:#4a4a4a;">You'll receive a signed copy by email when complete</td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<!-- Why am I receiving this — static info box (no JS; <details> unsupported in Outlook/Gmail) -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 20px;">
  <tr>
    <td style="background:#f9fbfc; border:1px solid #e8ebed; border-radius:8px; padding:16px 20px;">
      <p style="margin:0 0 8px; font-size:12px; font-weight:700; color:#162B3C; letter-spacing:0.04em; text-transform:uppercase;">Why am I receiving this?</p>
      <p style="margin:0; font-size:13px; color:#5a6572; line-height:1.65;">
        <strong style="color:#162B3C;"><%= requestor_name %></strong> at
        <strong style="color:#162B3C;"><%= @current_account.name %></strong>
        has requested your electronic signature on this agreement via IGSIGN, Ignition Group&rsquo;s internal e-signing platform.
        Signing is legally binding under the
        <strong style="color:#162B3C;">Electronic Communications and Transactions Act 25 of 2002</strong> (South Africa).
        <br><br>
        If you were not expecting this, or something looks unfamiliar, contact
        <a href="mailto:<%= requestor_email %>" style="color:#45AC34; text-decoration:none;"><%= requestor_email %></a> directly.
      </p>
    </td>
  </tr>
</table>

<!-- Closing -->
<p style="margin:0; font-size:14px; color:#162B3C;">
  Questions? Reply to this email or contact
  <a href="mailto:<%= requestor_email %>" style="color:#45AC34; text-decoration:none;"><%= requestor_email %></a>.
</p>

<% end %>
