<%# IGSIGN Landing / unauthenticated homepage %>
<div class="min-h-screen" style="background-color:#f5f7f9;">

  <%# Hero — Arctic Black gradient %>
  <section class="w-full py-20 text-center" style="background: linear-gradient(160deg, #162B3C 0%, #1e3a50 100%);">
    <div class="max-w-2xl mx-auto px-6">
      <div class="flex flex-col items-center">
        <%= render 'shared/logo', dark: true, height: '72', tagline: true %>
      </div>
      <p class="mt-8 text-base leading-relaxed" style="color:rgba(255,255,255,0.72); max-width:520px; margin-left:auto; margin-right:auto;">
        Ignition Group&rsquo;s internal e-signing platform. Structured approval workflows,
        ECT Act&ndash;compliant signatures, and full document audit trails &mdash; built for
        the way Ignition Group actually works.
      </p>
      <% unless signed_in? %>
        <div class="mt-10">
          <%= link_to new_user_session_path,
                class: 'inline-flex items-center gap-2 px-7 py-3 rounded font-semibold text-sm transition-all duration-150 hover:opacity-90',
                style: 'background-color:#45AC34; color:#ffffff; letter-spacing:0.04em; text-decoration:none;' do %>
            <%= svg_icon('login', class: 'w-4 h-4 text-white') %>
            <span>Sign In to IGSIGN</span>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <%# Feature cards %>
  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">

      <div class="bg-white rounded-xl p-6 border border-base-300 shadow-sm hover:shadow-md transition-shadow duration-200">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4" style="background-color:#162B3C;">
          <%= svg_icon('shield_check', class: 'w-5 h-5 text-white') %>
        </div>
        <h3 class="font-bold text-base mb-2" style="color:#162B3C;">ECT Act Compliant</h3>
        <p class="text-sm leading-relaxed" style="color:#7B787F;">
          SES-grade signatures valid under the Electronic Communications and Transactions Act 25 of 2002.
        </p>
      </div>

      <div class="bg-white rounded-xl p-6 border border-base-300 shadow-sm hover:shadow-md transition-shadow duration-200">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4" style="background-color:#162B3C;">
          <%= svg_icon('checks', class: 'w-5 h-5 text-white') %>
        </div>
        <h3 class="font-bold text-base mb-2" style="color:#162B3C;">Approval Workflows</h3>
        <p class="text-sm leading-relaxed" style="color:#7B787F;">
          CAF routing: BU Head &rarr; CLO &rarr; CFO &rarr; COO &rarr; CEO. Internal approvals stay internal.
        </p>
      </div>

      <div class="bg-white rounded-xl p-6 border border-base-300 shadow-sm hover:shadow-md transition-shadow duration-200">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4" style="background-color:#162B3C;">
          <%= svg_icon('file_text', class: 'w-5 h-5 text-white') %>
        </div>
        <h3 class="font-bold text-base mb-2" style="color:#162B3C;">Full Audit Trail</h3>
        <p class="text-sm leading-relaxed" style="color:#7B787F;">
          Every open, view and signature event timestamped and stored in your PostgreSQL database.
        </p>
      </div>

      <div class="bg-white rounded-xl p-6 border border-base-300 shadow-sm hover:shadow-md transition-shadow duration-200">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4" style="background-color:#162B3C;">
          <%= svg_icon('lock', class: 'w-5 h-5 text-white') %>
        </div>
        <h3 class="font-bold text-base mb-2" style="color:#162B3C;">Self-Hosted &amp; Private</h3>
        <p class="text-sm leading-relaxed" style="color:#7B787F;">
          Hosted entirely on Ignition Group infrastructure. No third-party SaaS. No data leaves your control.
        </p>
      </div>

    </div>
  </section>

  <%# Footer — Ignition Group %>
  <div style="background:#0e1e2a; border-top:1px solid rgba(255,255,255,0.06); padding:28px 32px;">
    <div style="max-width:960px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px;">

      <%# Logo — use white webp version designed for dark backgrounds %>
      <img src="/brand/ig-logo-white.webp" alt="Ignition Group"
           style="height:28px; width:auto; display:block; opacity:0.7;">

      <%# Right: compliance + contact %>
      <div style="font-size:11px; color:rgba(255,255,255,0.35); line-height:1.8; text-align:right;">
        ECT Act 25 of 2002 compliant &nbsp;&middot;&nbsp; Self-hosted &nbsp;&middot;&nbsp;
        <a href="mailto:legal@ignitiongroup.co.za"
           style="color:rgba(69,172,52,0.7); text-decoration:none;">legal@ignitiongroup.co.za</a>
      </div>

    </div>
  </div>

</div>
